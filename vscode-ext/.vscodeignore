# Exclude dev artifacts from the packaged .vsix. Only dist/, package.json,
# README, and CHANGELOG (if any) should ship.
.vscode/**
.vscode-test/**
src/**
.gitignore
.vscodeignore
tsconfig.json
esbuild.js
node_modules/**
# Local Node runtime installed via conda-forge for building on hosts
# without a system-wide Node 18+ (e.g. Kestrel login nodes). Huge and
# obviously not part of the shipped extension.
.conda-node/**
**/*.map
**/*.ts
**/*.vsix
