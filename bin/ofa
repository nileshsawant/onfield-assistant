#!/bin/bash
# ofa — OpenFOAM Assistant CLI wrapper

# Auto-detect OFA_ROOT from the script location so the wrapper is portable
# across installations. Honour an explicit override via the OFA_ROOT env var.
if [ -z "$OFA_ROOT" ]; then
    _OFA_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
    OFA_ROOT="$(cd "$(dirname "$_OFA_SCRIPT")/.." && pwd)"
fi
export OFA_ROOT

# Load per-site scheduler / module defaults from $OFA_ROOT/site.toml (via
# src/ofa_site.py). Populates OFA_SCHEDULER_* and OFA_MODULE_* vars used
# below with fallback precedence:
#   user env  >  site.toml  >  hard-coded Kestrel default (${VAR:-...})
# so an installer that never writes site.toml keeps the exact Kestrel
# behavior this launcher used to have inline.
if [ -x "$OFA_ROOT/env/bin/python3" ]; then
    _ofa_site_env="$("$OFA_ROOT/env/bin/python3" -c \
        "import sys; sys.path.insert(0, '$OFA_ROOT/src'); import ofa_site; sys.stdout.write(ofa_site._shell_export(ofa_site.load_site()))" \
        2>/dev/null)"
    if [ -n "$_ofa_site_env" ]; then
        eval "$_ofa_site_env"
    fi
    unset _ofa_site_env
fi

# If not inside a SLURM allocation, request a GPU node automatically
if [ -z "$SLURM_JOB_ID" ]; then
    if [ -z "${OFA_ACCOUNT:-}" ] && [ -n "${OFA_SCHEDULER_ACCOUNT_DISCOVERY:-}" ]; then
        ACCOUNT="$(bash -c "$OFA_SCHEDULER_ACCOUNT_DISCOVERY")"
    else
        ACCOUNT="${OFA_ACCOUNT:-$(sacctmgr show user "$USER" format=defaultaccount -n -P 2>/dev/null | head -1)}"
    fi
    if [ -z "$ACCOUNT" ]; then
        echo "ERROR: Could not determine your SLURM account." >&2
        echo "       Set OFA_ACCOUNT=<account> and retry." >&2
        exit 1
    fi
    PARTITION="${OFA_PARTITION:-${OFA_SCHEDULER_PARTITION_DEFAULT:-debug}}"
    WALLTIME="${OFA_WALLTIME:-${OFA_SCHEDULER_WALLTIME_DEFAULT:-00:30:00}}"
    _OFA_NTASKS="${OFA_SCHEDULER_NTASKS_PER_NODE:-32}"
    _OFA_MEM="${OFA_SCHEDULER_MEM:-80G}"
    _OFA_GRES="${OFA_GRES:-${OFA_SCHEDULER_GRES:-gpu:1}}"
    _OFA_JOB_NAME="${OFA_JOB_NAME:-ofa}"
    echo "Allocating GPU node (${PARTITION}, ${WALLTIME}, account: ${ACCOUNT})..." >&2
    exec salloc --job-name="$_OFA_JOB_NAME" -A "$ACCOUNT" -t "$WALLTIME" --nodes=1 --ntasks-per-node="$_OFA_NTASKS" \
              --mem="$_OFA_MEM" --gres="$_OFA_GRES" -p "$PARTITION" \
              srun --nodes=1 --ntasks=1 --pty "$0" "$@"
fi

# Running on compute node — set up environment
# Clean SLURM step variables and Cray PMI states completely so underlying 'srun' commands spawned by the AI can create fresh steps
for var in $(env | grep -E "^(SLURM_STEP|SLURM_SRUN|PMI|PMIX)_" | cut -d= -f1); do
    unset "$var"
done
unset SLURM_STEPID SLURM_TASK_PID SLURM_PROCID SLURM_LOCALID SLURM_GTIDS SLURM_NODEID SLURM_TASKS_PER_NODE

# Source the system profile so MODULEPATH (and the rest of the login-shell
# environment) is populated. Without this, subprocess.run(cmd, shell=True)
# inside ofa runs a non-login bash that skips /etc/profile.d/*, so things
# like `module load pytorch` fail because GPU-stack module paths are not in
# MODULEPATH — even on a GPU node.
#
# Caveat: some Kestrel profile-d scripts call `module purge` which clears
# OFA_ROOT (set by `setenv` in the assistant modulefile). We re-establish
# OFA_ROOT from this script's own path immediately afterwards so the rest
# of the wrapper sees the right value regardless of what the profile chain
# did.
source /etc/profile 2>/dev/null || true
_OFA_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
OFA_ROOT="$(cd "$(dirname "$_OFA_SCRIPT")/.." && pwd)"
export OFA_ROOT

export OLLAMA_MODELS="${OFA_ROOT}/models"
export OFA_VECTORDB="${OFA_ROOT}/vectordb"

# Force load the site's CUDA driver paths into the session so the Ollama
# daemon can natively bind to the local GPU hardware. site.toml supplies
# the module names (empty string = skip module load, useful on sites
# without Lmod). Fallbacks match the Kestrel-era hard-coded values.
if grep -q "release 9" /etc/redhat-release 2>/dev/null; then
    _ofa_cuda_mod="${OFA_MODULE_CUDA_RHEL9-cuda}"
else
    _ofa_cuda_mod="${OFA_MODULE_CUDA_RHEL8-cuda/12.4}"
fi
if [ -n "$_ofa_cuda_mod" ]; then
    module load "$_ofa_cuda_mod" 2>/dev/null || true
fi
unset _ofa_cuda_mod

export LD_LIBRARY_PATH="${OFA_ROOT}/lib:${LD_LIBRARY_PATH}"

exec "${OFA_ROOT}/env/bin/python3" "${OFA_ROOT}/src/ofa_main.py" "$@"
