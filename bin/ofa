#!/bin/bash
# ofa — OpenFOAM Assistant CLI wrapper

OFA_ROOT="${OFA_ROOT:-/nopt/nrel/apps/cpu_stack/software/openfoam/assistant}"

# If not inside a SLURM allocation, request a GPU node automatically
if [ -z "$SLURM_JOB_ID" ]; then
    ACCOUNT="${OFA_ACCOUNT:-$(sacctmgr show user "$USER" format=defaultaccount -n -P 2>/dev/null | head -1)}"
    if [ -z "$ACCOUNT" ]; then
        echo "ERROR: Could not determine your SLURM account." >&2
        echo "       Set OFA_ACCOUNT=<account> and retry." >&2
        exit 1
    fi
    PARTITION="${OFA_PARTITION:-debug}"
    WALLTIME="${OFA_WALLTIME:-00:30:00}"
    echo "Allocating GPU node (${PARTITION}, ${WALLTIME}, account: ${ACCOUNT})..." >&2
    exec salloc -A "$ACCOUNT" -t "$WALLTIME" --nodes=1 --ntasks-per-node=32 \
              --mem=80G --gres=gpu:1 -p "$PARTITION" \
              srun --nodes=1 --ntasks=1 --pty "$0" "$@"
fi

# Running on compute node — set up environment
# Clean SLURM step variables and Cray PMI states completely so underlying 'srun' commands spawned by the AI can create fresh steps
for var in $(env | grep -E "^(SLURM_STEP|SLURM_SRUN|PMI|PMIX)_" | cut -d= -f1); do
    unset "$var"
done
unset SLURM_STEPID SLURM_TASK_PID SLURM_PROCID SLURM_LOCALID SLURM_GTIDS SLURM_NODEID SLURM_TASKS_PER_NODE

export OLLAMA_MODELS="${OFA_ROOT}/models"
export OFA_VECTORDB="${OFA_ROOT}/vectordb"

# Force load Kestrel's CUDA driver paths into the session so the Ollama daemon can natively bind to the H100 hardware
# Handle both RHEL8 (cuda/12.4) and RHEL9 (cuda/12.8.1 or cuda)
if grep -q "release 9" /etc/redhat-release 2>/dev/null; then
    module load cuda 2>/dev/null || true
else
    module load cuda/12.4 2>/dev/null || true
fi

export LD_LIBRARY_PATH="${OFA_ROOT}/lib:${LD_LIBRARY_PATH}"

exec "${OFA_ROOT}/env/bin/python3" "${OFA_ROOT}/src/ofa_main.py" "$@"
